{
  "version": "1.0.0",
  "description": "Configuración para start-api: directorio de la API, comando y salud.",
  "apiWorkingDir": "src/Api",
  "command": "dotnet run",
  "defaultProfile": "Development",
  "defaultPort": 5020,
  "healthUrl": "http://127.0.0.1:5020/health",
  "healthCheckTimeoutSeconds": 30,
  "portBlocked": "fail",
  "dotnetConfiguration": "Release"
}
