{
  "version": "1.0.0",
  "description": "Configuracion para Invoke-MySqlSeeds: migraciones EF y seeds Product (GesFer.Product.Back).",
  "efProject": "src/Infrastructure/GesFer.Infrastructure.csproj",
  "startupProject": "src/Api/GesFer.Api.csproj",
  "seedsProject": "src/Api/GesFer.Api.csproj",
  "seedsPath": "src/Infrastructure/Data/Seeds",
  "connectionEnv": "ConnectionStrings__DefaultConnection",
  "runMigrations": true,
  "runSeeds": true,
  "mysqlContainerName": "GesFer_product_db",
  "healthCheck": {
    "mysqlPingMaxAttempts": 15,
    "mysqlPingRetrySeconds": 2
  }
}
